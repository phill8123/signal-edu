# PostgreSQL (Supabase 연결 문자열)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT 비밀키 (랜덤 문자열 — openssl rand -hex 32)
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CORS 허용 오리진
ALLOWED_ORIGINS=http://localhost:5173,https://signal-edu.vercel.app

# 토스페이먼츠 (https://developers.tosspayments.com)
TOSS_SECRET_KEY=test_sk_placeholder
TOSS_CLIENT_KEY=test_ck_placeholder
